# ============================================================
# Backend Environment Variables — Template
# Sao chép file này thành .env rồi điền giá trị thật.
#   cp .env.example .env
# ============================================================

# GitHub Models API Token (lấy tại https://github.com/settings/tokens)
# Cần quyền: Models API (read)
GITHUB_MODELS_TOKEN=your_github_personal_access_token_here

# (Tuỳ chọn) Tên model — mặc định gpt-4o
# GITHUB_MODELS_MODEL_NAME=gpt-4o

# PostgreSQL — để trống sẽ dùng giá trị mặc định trong application.properties
# DB_URL=jdbc:postgresql://localhost:5432/price_tracker
# DB_USERNAME=postgres
# DB_PASSWORD=your_db_password
